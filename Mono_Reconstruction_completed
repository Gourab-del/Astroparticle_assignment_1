   "source": [
    "#variation of Energy vs hillas parameters/timing parameters\n",
    "\n",
    "# ---------------- FUNCTION ----------------\n",
    "def dl1_parameters(geom, image, peak_time):\n",
    "\n",
    "    # ---- Cleaning ----\n",
    "    clean = tailcuts_clean(\n",
    "        geom,\n",
    "        image,\n",
    "        picture_thresh=6,\n",
    "        boundary_thresh=3\n",
    "    )\n",
    "\n",
    "    cleaned_image = image.copy()\n",
    "    cleaned_image[~clean] = 0\n",
    "\n",
    "    # ---- Island detection ----\n",
    "    num_islands, island_labels = number_of_islands(geom, clean)\n",
    "\n",
    "    # Skip if no island\n",
    "    if num_islands == 0:\n",
    "        return None, None\n",
    "\n",
    "    # ---- Find brightest island ----\n",
    "    intensities = [\n",
    "        cleaned_image[island_labels == i].sum()\n",
    "        for i in range(1, num_islands + 1)\n",
    "    ]\n",
    "\n",
    "    brightest_id = np.argmax(intensities) + 1\n",
    "    brightest_mask = island_labels == brightest_id\n",
    "\n",
    "    # ---- Hillas parameters ----\n",
    "    H_pm = hillas_parameters(\n",
    "        geom[brightest_mask],\n",
    "        cleaned_image[brightest_mask]\n",
    "    )\n",
    "\n",
    "    # ---- Timing parameters ----\n",
    "    T_pm = timing_parameters(\n",
    "        hillas_parameters=H_pm,\n",
    "        geom=geom[brightest_mask],\n",
    "        image=cleaned_image[brightest_mask],\n",
    "        peak_time=peak_time[brightest_mask]\n",
    "    )\n",
    "\n",
    "    return T_pm, H_pm\n",
    "\n",
    "\n",
    "# ---------------- DATA COLLECTION ----------------\n",
    "T_slope = []\n",
    "T_intercept = []\n",
    "T_deviation = []\n",
    "E_simulation = []\n",
    "H_intensity = []\n",
    "H_length = []\n",
    "H_width = []\n",
    "\n",
    "for i in range(min(1000, len(single_events))):\n",
    "    event = single_events[i]\n",
    "\n",
    "    image = event.dl1.tel[tel_id].image\n",
    "    peak_time = event.dl1.tel[tel_id].peak_time\n",
    "\n",
    "    T_pm, H_pm = dl1_parameters(camera_geometry, image, peak_time)\n",
    "\n",
    "    # Skip bad events\n",
    "    if T_pm is None or H_pm is None:\n",
    "        continue\n",
    "\n",
    "    # ---- Store values ----\n",
    "    T_slope.append(T_pm['slope'].value)\n",
    "    T_intercept.append(T_pm['intercept'])\n",
    "    T_deviation.append(T_pm['deviation'])\n",
    "\n",
    "    E_simulation.append(event.simulation.shower.energy.to(\"TeV\").value)\n",
    "\n",
    "    H_intensity.append(H_pm['intensity'])\n",
    "    H_length.append(H_pm['length'].value)\n",
    "    H_width.append(H_pm['width'].value)\n",
    "\n",
    "\n",
    "# ---------------- CONVERT TO ARRAYS ----------------\n",
    "T_slope_array = np.array(T_slope)\n",
    "T_intercept_array = np.array(T_intercept)\n",
    "T_deviation_array = np.array(T_deviation)\n",
    "E_array = np.array(E_simulation)\n",
    "H_intensity_array = np.array(H_intensity)\n",
    "H_length_array = np.array(H_length)\n",
    "H_width_array = np.array(H_width)\n",
    "\n",
    "\n",
    "# ---------------- PLOTTING ----------------\n",
    "fig, ax = plt.subplots(5, 1, figsize=(8, 25))\n",
    "\n",
    "# 1️⃣ Timing slope vs Energy\n",
    "ax[0].plot(T_slope_array, E_array, 'o',color='orange')\n",
    "ax[0].set_xlabel('Timing Slope (ns/pixel)')\n",
    "ax[0].set_ylabel('Energy (TeV)')\n",
    "ax[0].set_title('Timing Slope vs Energy')\n",
    "\n",
    "# 2️⃣ Timing deviation vs Energy\n",
    "ax[1].plot(T_deviation_array, E_array, 'o',color='blue')\n",
    "ax[1].set_xlabel('Timing Deviation (ns)')\n",
    "ax[1].set_ylabel('Energy (TeV)')\n",
    "ax[1].set_title('Timing Deviation vs Energy')\n",
    "\n",
    "# 3️⃣ Intensity vs Energy\n",
    "ax[2].plot(H_intensity_array, E_array, 'o',color='red')\n",
    "ax[2].set_xlabel('Hillas Intensity (p.e.)')\n",
    "ax[2].set_ylabel('Energy (TeV)')\n",
    "ax[2].set_title('Intensity vs Energy')\n",
    "\n",
    "# 4️⃣ Length vs Energy\n",
    "ax[3].plot(H_length_array, E_array, 'o',color='green')\n",
    "ax[3].set_xlabel('Hillas Length (deg)')\n",
    "ax[3].set_ylabel('Energy (TeV)')\n",
    "ax[3].set_title('Length vs Energy')\n",
    "\n",
    "# 5️⃣ Width vs Energy\n",
    "ax[4].plot(H_width_array, E_array, 'o',color='purple')\n",
    "ax[4].set_xlabel('Hillas Width (deg)')\n",
    "ax[4].set_ylabel('Energy (TeV)')\n",
    "ax[4].set_title('Width vs Energy')\n",
    "\n",
    "\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
