    "#getting the brightest island\n",
    "\n",
    "\n",
    "# find brightest island\n",
    "max_intensity = 0\n",
    "brightest_island = None\n",
    "\n",
    "for island_id in range(1, number_islands + 1):\n",
    "    island_mask = island_labels == island_id\n",
    "    intensity = image[island_mask].sum()\n",
    "    \n",
    "    if intensity > max_intensity:\n",
    "        max_intensity = intensity\n",
    "        brightest_island = island_id\n",
    "\n",
    "# create mask for brightest island\n",
    "brightest_mask = island_labels == brightest_island\n",
    "\n",
    "# create image with only brightest island\n",
    "brightest_image = image.copy()\n",
    "brightest_image[~brightest_mask] = 0\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(10, 5))\n",
    "\n",
    "# 1️⃣ Original image\n",
    "axes[0].set_title(\"Original Image\")\n",
